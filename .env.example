OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_MODEL=gpt-4o-mini
TRANSLATION_TARGET_LANGUAGE=Vietnamese
OUTPUT_TOKEN_FACTOR=1.18
TRANSLATION_BATCH_MAX_ITEMS=16
TRANSLATION_BATCH_MAX_TOKENS=3500
TRANSLATION_CONCURRENCY=4
OCR_ENABLED=true
OCR_DPI=220
OCR_LANGUAGE=eng
OCR_MIN_CONFIDENCE=25
OCR_FALLBACK_SEGMENT_THRESHOLD=3
RENDER_PAGES_PER_CHUNK=6
JOB_TIMEOUT_TRANSLATE_SECONDS=2700
JOB_TIMEOUT_RENDER_SECONDS=3600
JOB_TIMEOUT_SAVE_SECONDS=900
WARNING_OUTPUT_GROWTH_FACTOR=4.0
MAX_OUTPUT_GROWTH_FACTOR=8.0
PORT=8000
